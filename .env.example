# HomeOps — example environment. Copy to `.env` (gitignored) and adjust.
# NEVER put real secrets in this file; it is committed.

# ── Backend (read by backend/app/config.py via APP_ENV) ──────────────────────
APP_ENV=development                       # development | testing | production

# Database. The app connects with a NON-superuser, NON-BYPASSRLS role so RLS is
# actually enforced (spec §7.2) — a superuser would silently bypass RLS.
# Migrations run with the privileged owner role and create the app role + grants.
DATABASE_URL=postgresql+psycopg://homeops_app:homeops_app@localhost:5432/homeops
MIGRATION_DATABASE_URL=postgresql+psycopg://homeops:homeops@localhost:5432/homeops

# JWT access token signing (HS256). Generate a strong random value for real envs.
JWT_SECRET_KEY=dev-only-change-me-please-using-a-long-random-string
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# Argon2id parameters (argon2-cffi). Memory cost in KiB (>= 65536 = 64 MiB).
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=2

# Activation / invitation token lifetime (hours).
ACTIVATION_TOKEN_TTL_HOURS=24

# SMTP (dev/test → Mailpit; prod → transactional provider).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM="HomeOps <no-reply@homeops.localhost>"
MAIL_DEFAULT_LOCALE=hu

# Public base URL used to build activation/invite links (behind the proxy).
PUBLIC_BASE_URL=https://homeops.localhost

# SecretCipher KEK (envelope encryption MVP — pgcrypto/env, spec §10.5). Base64.
SECRET_KEK=aG9tZW9wc19kZXZfa2VrXzAxMjM0NTY3ODlhYmNkZWY=

# OpenAPI interactive docs (dev: true; prod: false → 404, spec §7.4).
ENABLE_API_DOCS=true

# Rate limiting storage (in-memory for dev; Redis URL for shared limits in prod).
RATELIMIT_STORAGE_URI=memory://

# ── Frontend (Vite — only VITE_* vars are exposed to the browser; no secrets) ─
VITE_API_BASE_URL=/api
