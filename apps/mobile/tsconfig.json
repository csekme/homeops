{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"],
      "@homeops/core": ["../../packages/core/src/index.ts"],
      "@homeops/validation": ["../../packages/validation/src/index.ts"],
      "@homeops/i18n": ["../../packages/i18n/src/index.ts"],
      "@homeops/tokens": ["../../packages/tokens/src/index.ts"],
      "@homeops/types": ["../../packages/types/src/index.ts"],
      "@homeops/api-client": ["../../packages/api-client/src/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}