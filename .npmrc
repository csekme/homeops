# Metro (React Native bundler, apps/mobile) resolves modules by walking node_modules and
# does not understand pnpm's strict symlinked store, so transitive deps it expects to be
# hoisted (@babel/runtime, react-native-css-interop, @expo/metro-runtime, …) appear missing.
# Hoisting every dependency to the root node_modules is the Expo-recommended fix for pnpm
# monorepos. It is additive — web/backend resolution is unaffected (the @types/react clash
# is already pinned via the root pnpm.overrides).
shamefully-hoist=true
