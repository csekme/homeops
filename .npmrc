# Expo + Metro need a flat node_modules to resolve React Native and its native
# modules from a single copy. pnpm's default isolated store breaks Metro's haste
# map, so the workspace uses hoisted linking (Expo's documented monorepo setup:
# https://docs.expo.dev/guides/monorepos/). Web (Vite) and the backend are unaffected.
node-linker=hoisted

# Some React Native deps (e.g. @gluestack-ui/utils) import transitive scoped packages
# they don't declare (@react-aria/*, @react-stately/*). Metro has no peer-resolution
# fallback, so flatten everything to the top-level node_modules like npm/yarn do.
shamefully-hoist=true
